{
  "name": "@clawops/cli",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "bin": {
    "clawops": "./dist/index.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",

    "db:studio": "drizzle-kit studio",
    "clean": "rm -rf dist",
    "lint": "eslint src/",
    "test": "echo \"No tests yet\""
  },
  "dependencies": {
    "better-sqlite3": "^11.7.0",
    "drizzle-orm": "^0.38.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "drizzle-kit": "^0.30.0",
    "typescript": "^5.7.0"
  }
}
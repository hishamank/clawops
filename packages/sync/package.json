{
  "name": "@clawops/sync",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "rm -rf dist && tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "clean": "rm -rf dist",
    "test": "node --experimental-test-module-mocks --import tsx/esm --test src/*.test.mts src/**/*.test.mts"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0"
  },
  "dependencies": {
    "@clawops/core": "workspace:*",
    "drizzle-orm": "^0.38.0"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./openclaw": {
      "import": "./dist/openclaw/index.js",
      "types": "./dist/openclaw/index.d.ts"
    }
  }
}
